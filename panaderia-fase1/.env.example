# Neon (https://console.neon.tech) → cadena "Pooled connection"
DATABASE_URL="postgresql://usuario:password@host-pooler.neon.tech/panaderia?sslmode=require"
# La misma cadena pero SIN "-pooler" (conexión directa, la usan las migraciones)
DIRECT_URL="postgresql://usuario:password@host.neon.tech/panaderia?sslmode=require"

# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-por-un-secreto-largo"

# URL pública (en local: http://localhost:3000; en Vercel se define sola)
AUTH_URL="http://localhost:3000"

# Clave de la API de Anthropic (se usa desde las Fases 4 y 5)
ANTHROPIC_API_KEY=""

# Secreto que protege el endpoint del cron dominical
CRON_SECRET="cambiar-por-otro-secreto"
